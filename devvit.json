{
  "$schema": "https://developers.reddit.com/schema/config-file.v1.json",
  "name": "modscope",
  "permissions": {
    "reddit": true,
    "redis": true,
    "http": {
      "enable": true,
      "domains": ["raw.githubusercontent.com"]
    }
  },
  "post": {
    "dir": "dist/client",
    "entrypoints": {
      "default": {
        "inline": true,
        "entry": "dashboard.html"
      },
      "expanded": {
        "entry": "dashboard.html"
      }
    }
  },
  "server": {
    "dir": "dist/server",
    "entry": "index.cjs"
  },
  "media": {
    "dir": "assets/"
  },
  "marketingAssets": {
    "icon": "assets/icon.png"
  },
  "menu": {
    "items": [
      {
        "label": "Open ModScope Dashboard",
        "description": "View subreddit analytics and insights",
        "location": "subreddit",
        "forUserType": "moderator",
        "endpoint": "/internal/menu/open-dashboard"
      },
      {
        "label": "Reset Launcher Post",
        "location": "subreddit",
        "forUserType": "moderator",
        "endpoint": "/internal/menu/clear-cache"
      }
    ]
  },
  "triggers": {
    "onAppInstall": "/internal/triggers/on-app-install"
  },
  "scheduler": {
    "tasks": {
      "snapshot-worker": {
        "endpoint": "/internal/triggers/tasks/snapshot-worker"
      },
      "delete-snapshot": {
        "endpoint": "/internal/triggers/tasks/delete-snapshot"
      },
      "check-for-updates": {
        "endpoint": "/internal/triggers/tasks/check-for-updates",
        "cron": "0 9 * * 1"
      }
    }
  },
  "dev": {
    "subreddit": "modscope_dev"
  },
  "scripts": {
    "dev": "vite build --watch",
    "build": "vite build"
  }
}
